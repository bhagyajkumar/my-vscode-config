{
    // =========================
    // Appearance
    // =========================
    "workbench.colorTheme": "Fleet Purple",
    "workbench.iconTheme": "material-icon-theme",
    "window.titleBarStyle": "custom",
    // =========================
    // Fonts
    // =========================
    "editor.fontFamily": "JetBrains Mono",
    "editor.fontSize": 15,
    "editor.fontWeight": "400",
    "editor.lineHeight": 26,
    "editor.letterSpacing": 0.2,
    "editor.fontLigatures": true,
    // Terminal
    "terminal.integrated.fontFamily": "JetBrainsMono NFM",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.lineHeight": 1.2,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorBlinking": true,
    // =========================
    // Editor
    // =========================
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "selection",
    "editor.guides.bracketPairs": true,
    "editor.guides.indentation": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "editor.linkedEditing": true,
    "editor.occurrencesHighlight": "singleFile",
    "editor.selectionHighlight": false,
    // =========================
    // Formatting
    // =========================
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    // =========================
    // Explorer
    // =========================
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    // =========================
    // Tabs
    // =========================
    "workbench.editor.enablePreview": false,
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.wrapTabs": true,
    // =========================
    // Cursor
    // =========================
    "editor.cursorBlinking": "smooth",
    "editor.cursorStyle": "line-thin",
    // =========================
    // Suggestions
    // =========================
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
    },
    "editor.suggestSelection": "recentlyUsed",
    "editor.acceptSuggestionOnCommitCharacter": false,
    // =========================
    // Files
    // =========================
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 800,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    // =========================
    // Git
    // =========================
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    // =========================
    // UI
    // =========================
    "breadcrumbs.enabled": false,
    "workbench.tree.indent": 18,
    "window.commandCenter": false,
    "zenMode.fullScreen": false,
    "zenMode.centerLayout": false,
    // Cursor
    "editor.cursorWidth": 1,
    // Scrolling
    "terminal.integrated.smoothScrolling": true,
    // Editor
    "editor.scrollBeyondLastLine": false,
    "editor.wordWrap": "off",
    "editor.matchBrackets": "near",
    "editor.hover.delay": 250,
    "editor.hover.sticky": true,
    // Inline suggestions
    "editor.inlineSuggest.suppressSuggestions": false,
    // UI
    "window.menuBarVisibility": "toggle",
    "window.zoomLevel": 0,
    "window.density.editorTabHeight": "compact",
    // Explorer
    "explorer.openEditors.visible": 0,
    // Tabs
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabActionLocation": "left",
    // Status Bar
    "workbench.statusBar.visible": true,
    // Startup
    "workbench.startupEditor": "none",
    // Terminal
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    // Performance
    "editor.experimental.asyncTokenization": true,
    "editor.experimental.asyncTokenizationVerification": false,
    // Decorations
    "editor.lightbulb.enabled": "off",
    "editor.codeLens": false,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4o-mini",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    }
}
